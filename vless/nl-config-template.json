{
  "log": {
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "vless-cascade-in",
      "listen": "0.0.0.0",
      "port": __NL_XRAY_PORT__,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "__CASCADE_UUID__"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "__NL_REALITY_SNI__:443",
          "xver": 0,
          "serverNames": ["__NL_REALITY_SNI__"],
          "privateKey": "__NL_REALITY_PRIVATE_KEY__",
          "shortIds": ["__NL_REALITY_SHORT_ID__"]
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {}
    },
    {
      "tag": "block",
      "protocol": "blackhole",
      "settings": {}
    }
  ],
  "routing": {
    "rules": [
      {
        "type": "field",
        "outboundTag": "block",
        "protocol": ["bittorrent"]
      }
    ]
  }
}
