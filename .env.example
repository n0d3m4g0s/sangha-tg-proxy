# VM addresses
DUTCH_VM_IP=203.0.113.1
DUTCH_VM_HOST=proxy-nl.example.com
RUSSIAN_VM_IP=203.0.113.2
RUSSIAN_VM_HOST=proxy-ru.example.com

# SSH keys (relative to project root)
DEPLOY_KEY_PATH=./keys/deploy_ed25519

# Owner's public SSH key (for manual access to VMs)
OWNER_PUB_KEY="ssh-ed25519 AAAA... your@email.com"

# Email for Let's Encrypt certificate
CERTBOT_EMAIL=your@email.com

# Webhook API
SANGHA_API_KEY=changeme_run_openssl_rand_hex_32

# MTProto proxy
MTP_SECRET=changeme_run_openssl_rand_hex_16
TLS_DOMAIN=ya.ru
PROXY_PORT=3128
PUBLIC_PORT=443
CONNECTION_LIMIT=16

# Monitoring (Telegram bot)
SANGHA_BOT_TOKEN=changeme
SANGHA_ADMIN_CHAT_ID=changeme
